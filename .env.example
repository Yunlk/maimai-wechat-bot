# maimaiDX WeChat Bot 配置
# 复制此文件为 .env 并填写

# 静态资源路径（默认 ./static）
MAIMAIDX_STATIC_PATH=./static

# 水鱼查分器（可选，用于 B50 等高级功能）
DIVINGFISH_TOKEN=
DIVINGFISH_PROBER_PROXY=false

# 落雪查分器（可选）
LXNS_DEV_TOKEN=
LX_CLIENT_ID=
LX_CLIENT_SECRET=
REDIRECT_URI=

# Gewechat 连接
GEWECHAT_BASE_URL=http://gewechat:2531
GEWECHAT_TOKEN=
GEWECHAT_CALLBACK_URL=http://maimai-bot:8080/webhook
GEWECHAT_APP_ID=

# 机器人服务
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# 杂项
BOT_NAME=maimaiDX
SAVE_IN_MEMORY=true
ASSETS_ONLINE=true
MAIMAIDX_ALIAS_PUSH=true
