# ───── WeChatFerry ─────
# WCF_HOST=           # 远程 wcf 地址（留空=本地启动）
# WCF_PORT=10086      # wcf RPC 端口（默认 10086）

# ───── 水鱼查分器（可选） ─────
DIVINGFISH_TOKEN=

# ───── 落雪查分器（可选） ─────
LXNS_DEV_TOKEN=

# ───── 资源路径（可选，默认 ./static） ─────
# MAIMAIDX_STATIC_PATH=./static

# ───── B50 图片保存目录（可选，留空不保存） ─────
# SAVE_B50_DIR=./b50_results
